{
  "name": "localazy-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Localazy translation management API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "localazy-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "node --import tsx --test test/**/*.test.ts",
